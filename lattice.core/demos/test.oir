module Test version 1.0.0

class ModuleInfo
{
    field CompilerName: System.String
    field CompilerVersion: Syste.String
    field CompilerArgs: System.String
    field DebugInfo: List<DebugInfo>
}

class Debuginfo
{
    field startline: System.int
    field endline: System.int
    field startColum: system.int
    field endColum: System.int
    field SourceFile: System.String
    field instruction: System.String
}

class Program
{
    
    method constructor() -> void {
        ret
    }
    static method Meowo() -> void {
        call Program.Meowt() -> void
    }

    static method Meowt() -> void {
        call Program.Meowv() -> void
    }

    static method Meowv() -> void {
        call Program.Meows() -> void
    }

    static method Meows() -> void {
        call IO.Println(System.string) -> void
    }

	static method Main(args: System.string[]) -> void {
        ldstr "$>"
        call  IO.Print(System.string) -> void
        ldstr "meow"
        call  IO.Readln() -> string
        cne
        if (stack)
        {
            ldstr "invalid command"
            call Program.Meowo(System.string) -> void
        }
        ret
    }
}